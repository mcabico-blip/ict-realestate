generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  BROKER
  SALESPERSON
  LAWYER
  ADMIN
}

enum ProfessionalType {
  BROKER
  SALESPERSON
  LAWYER
}

enum ListingType {
  FOR_SALE
  FOR_RENT
  FOR_LEASE
}

enum PropertyType {
  HOUSE
  CONDO
  APARTMENT
  TOWNHOUSE
  LOT
  COMMERCIAL
  WAREHOUSE
  OFFICE
  FARM
}

enum PropertyStatus {
  ACTIVE
  PENDING
  SOLD
  RENTED
  INACTIVE
}

enum InquiryStatus {
  OPEN
  RESPONDED
  CLOSED
}

enum EngagementStatus {
  NEW                  // Buyer just engaged a lawyer; lawyer hasn't reviewed yet
  IN_REVIEW            // Lawyer is reviewing the property/title
  AWAITING_DOCUMENTS   // Waiting on parties to provide source docs (TCT, Tax Dec, IDs, etc.)
  DRAFTING             // Lawyer drafting Contract to Sell / Deed of Sale
  PENDING_SIGNATURES   // Documents ready, awaiting signatures from parties
  NOTARIZED            // Documents notarized; ready for filing
  TITLE_TRANSFER       // BIR/CAR/Registry of Deeds processing
  COMPLETED            // Title transferred, deal closed
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          UserRole  @default(BUYER)
  // Presence: when this user last hit an authed API. Used to surface
  // "online now" indicators and to bias broker/lawyer suggestion order.
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  properties          Property[]
  inquiries           Inquiry[]    @relation("BuyerInquiries")
  responses           Inquiry[]    @relation("AgentInquiries")
  favorites           Favorite[]
  professionalProfile ProfessionalProfile?
  legalConsultations  LegalConsultation[] @relation("ClientConsultations")
  legalResponses      LegalConsultation[] @relation("LawyerConsultations")
  engagementsAsBuyer     Engagement[]       @relation("BuyerEngagements")
  engagementsAsLawyer    Engagement[]       @relation("LawyerEngagements")
  engagementsInitiated   Engagement[]       @relation("EngagementsInitiated")
  uploadedDocuments      ContractDocument[] @relation("DocumentUploader")
  conversationsAsBuyer   Conversation[]     @relation("BuyerConversations")
  sentMessages           Message[]          @relation("MessageSender")
  selectedOnProperties   Property[]         @relation("SelectedBuyerOnProperty")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Unified profile for Brokers, Salespersons, and Lawyers
model ProfessionalProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  professionalType ProfessionalType

  // Common fields
  bio          String?  @db.Text
  photoUrl     String?
  yearsExp     Int?
  city         String?
  province     String?
  verified     Boolean  @default(false)
  featured     Boolean  @default(false)
  languages    String[]
  socialFb     String?
  socialLinked String?

  // Broker / Salesperson fields
  licenseNo        String?  // PRC Real Estate License No.
  licenseExpiry    DateTime?
  prcIdNo          String?
  accreditationNo  String?  // For salespersons under RESA Law
  supervisingBroker String? // Salesperson's supervising broker name
  realtorBoard     String?  // e.g. "PAREB - Makati Board"
  agency           String?
  agencyAddress    String?
  specialties      String[] // Residential, Commercial, Industrial, etc.

  // Lawyer fields
  ibpRollNo       String?  // Integrated Bar of the Philippines Roll No.
  ibpChapter      String?  // e.g. "IBP Makati Chapter"
  lawFirm         String?
  lawFirmAddress  String?
  barYear         Int?     // Year passed the bar
  lawSpecialties  String[] // Title transfer, foreclosure, ejectment, lease drafting, etc.
  notaryUntil     DateTime? // Commission as Notary Public valid until

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([professionalType, verified])
  @@index([city, province])
}

model LegalConsultation {
  id         String        @id @default(cuid())
  clientId   String
  lawyerId   String
  subject    String
  message    String        @db.Text
  status     InquiryStatus @default(OPEN)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  client User @relation("ClientConsultations", fields: [clientId], references: [id], onDelete: Cascade)
  lawyer User @relation("LawyerConsultations", fields: [lawyerId], references: [id])
}

model Property {
  id           String         @id @default(cuid())
  title        String
  description  String         @db.Text
  listingType  ListingType
  propertyType PropertyType
  status       PropertyStatus @default(ACTIVE)
  price        Decimal        @db.Decimal(15, 2)
  priceUnit    String         @default("PHP")
  negotiable   Boolean        @default(false)

  address      String
  city         String
  municipality String?
  province     String
  region       String
  zipCode      String?
  latitude     Float?
  longitude    Float?

  lotArea       Float?
  floorArea     Float?
  bedrooms      Int?
  bathrooms     Int?
  parkingSpaces Int?
  floors        Int?
  yearBuilt     Int?
  furnished     Boolean @default(false)
  petFriendly   Boolean @default(false)

  ownerId   String
  // When the seller (via their broker) selects one buyer to move forward
  // with on this property, this points to that buyer's user ID. Other
  // inquiries auto-close once this is set. When the related engagement
  // completes, property.status moves to SOLD.
  selectedBuyerId String?
  featured  Boolean  @default(false)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  selectedBuyer User?             @relation("SelectedBuyerOnProperty", fields: [selectedBuyerId], references: [id])
  images        PropertyImage[]
  amenities     PropertyAmenity[]
  inquiries     Inquiry[]
  favorites     Favorite[]
  engagements   Engagement[]
  conversations Conversation[]

  @@index([city, province])
  @@index([listingType, propertyType])
  @@index([status, featured])
  @@index([price])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  key        String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyAmenity {
  id         String @id @default(cuid())
  propertyId String
  name       String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id         String        @id @default(cuid())
  propertyId String
  buyerId    String
  agentId    String?
  message    String        @db.Text
  status     InquiryStatus @default(OPEN)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer    User     @relation("BuyerInquiries", fields: [buyerId], references: [id], onDelete: Cascade)
  agent    User?    @relation("AgentInquiries", fields: [agentId], references: [id])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

// Engagement = a lawyer is tagged to handle the legal/contract work for a specific
// buyer-property deal. Can be initiated by the buyer themselves OR by the listing's
// broker/salesperson on behalf of an inquiring buyer.
// Documents (Deed of Sale, TCT, etc.) hang off this.
model Engagement {
  id            String           @id @default(cuid())
  buyerId       String
  lawyerId      String
  propertyId    String
  initiatedById String           // who tagged the lawyer — buyer themselves or the broker
  status        EngagementStatus @default(NEW)
  notes         String?          @db.Text // lawyer's running notes, visible to buyer
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  buyer       User               @relation("BuyerEngagements", fields: [buyerId], references: [id], onDelete: Cascade)
  lawyer      User               @relation("LawyerEngagements", fields: [lawyerId], references: [id])
  initiatedBy User               @relation("EngagementsInitiated", fields: [initiatedById], references: [id])
  property    Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  documents   ContractDocument[]

  @@unique([buyerId, propertyId]) // one engagement per buyer per property
  @@index([lawyerId, status])
  @@index([buyerId])
}

model ContractDocument {
  id           String   @id @default(cuid())
  engagementId String
  documentType String   // "Deed of Sale", "Tax Declaration", "TCT", "Contract to Sell", etc.
  fileName     String   // original filename for display
  fileKey      String   // storage key (path under contracts/{engagementId}/)
  fileSize     Int      // bytes
  mimeType     String   // application/pdf, image/jpeg, etc.
  uploadedById String
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([engagementId])
}

// Conversation = a chat thread for a specific buyer + property pair.
// Participants are derived at API time:
//   - The buyer (always)
//   - The property owner / their broker (always, as the listing's agent)
//   - The lawyer (only when an Engagement exists for this buyer+property)
// One conversation per buyer-property pair; a new chat starts as soon as
// the buyer is interested. The conversation carries through to engagement.
model Conversation {
  id         String   @id @default(cuid())
  buyerId    String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([buyerId, propertyId])
  @@index([propertyId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  // Array of userIds who've read this message. Sender is implicitly counted.
  readBy         String[] @default([])
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}
